name: Publish to PyPI

on:
  release:
    types: [published]
  push:
    tags:
      - 'v*.*.*'

env:
  PYTHONUNBUFFERED: 1

jobs:
  # Pre-publication validation
  validate-release:
    name: Validate Release
    runs-on: ubuntu-latest

    steps:
    - uses: actions/checkout@v4

    - name: Set up Python 3.11
      uses: actions/setup-python@v5
      with:
        python-version: "3.11"
        cache: 'pip'
        cache-dependency-path: 'pyproject.toml'

    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install -e ".[dev]"

    - name: Validate version tag
      run: |
        # Extract version from tag
        TAG_VERSION="${GITHUB_REF#refs/tags/v}"
        echo "Tag version: $TAG_VERSION"

        # Get version from package
        PACKAGE_VERSION=$(python -c "from importlib.metadata import version; print(version('preprimer'))" 2>/dev/null || echo "unknown")
        echo "Package version: $PACKAGE_VERSION"

        # Verify tag format
        if [[ ! "$TAG_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
          echo "❌ Invalid version tag format. Expected: v0.0.0"
          exit 1
        fi

        echo "✅ Version tag validation passed"

    - name: Run full test suite
      run: |
        python -m pytest tests/ \
          --cov=preprimer \
          --cov-report=xml \
          --cov-report=term-missing \
          --tb=short \
          -x

    - name: Verify test coverage
      run: |
        COVERAGE=$(python -c "import xml.etree.ElementTree as ET; tree = ET.parse('coverage.xml'); print(tree.getroot().attrib['line-rate'])")
        COVERAGE_PERCENT=$(python -c "print(f'{float('$COVERAGE') * 100:.2f}')")
        echo "Coverage: ${COVERAGE_PERCENT}%"

        if (( $(echo "$COVERAGE < 0.95" | bc -l) )); then
          echo "❌ Coverage below 95% threshold: ${COVERAGE_PERCENT}%"
          exit 1
        fi

        echo "✅ Coverage check passed: ${COVERAGE_PERCENT}%"

    - name: Run security checks
      run: |
        pip install bandit safety
        bandit -r preprimer/ -ll
        safety check --continue-on-error

    - name: Verify documentation
      run: |
        # Check critical documentation files exist
        FILES=("README.md" "CHANGELOG.md" "LICENSE" "RELEASE_CHECKLIST.md")
        for file in "${FILES[@]}"; do
          if [[ ! -f "$file" ]]; then
            echo "❌ Missing required file: $file"
            exit 1
          fi
          echo "✅ Found: $file"
        done

    - name: Check CHANGELOG entry
      run: |
        TAG_VERSION="${GITHUB_REF#refs/tags/v}"

        if ! grep -q "\[$TAG_VERSION\]" CHANGELOG.md; then
          echo "❌ No CHANGELOG entry found for version $TAG_VERSION"
          echo "Please update CHANGELOG.md with release notes"
          exit 1
        fi

        echo "✅ CHANGELOG entry found for $TAG_VERSION"

  # Build distribution packages
  build-package:
    name: Build Distribution
    runs-on: ubuntu-latest
    needs: validate-release

    steps:
    - uses: actions/checkout@v4
      with:
        fetch-depth: 0  # Full history for setuptools-scm

    - name: Set up Python 3.11
      uses: actions/setup-python@v5
      with:
        python-version: "3.11"
        cache: 'pip'

    - name: Install build dependencies
      run: |
        python -m pip install --upgrade pip
        pip install build twine

    - name: Clean previous builds
      run: |
        rm -rf dist/ build/ *.egg-info

    - name: Build source distribution and wheel
      run: |
        python -m build

    - name: List build artifacts
      run: |
        ls -lh dist/
        echo ""
        echo "📦 Distribution packages:"
        for file in dist/*; do
          echo "  - $(basename $file) ($(du -h $file | cut -f1))"
        done

    - name: Verify package contents
      run: |
        # Check wheel contents
        python -m pip install wheel
        for whl in dist/*.whl; do
          echo ""
          echo "🔍 Checking wheel: $(basename $whl)"
          python -m wheel unpack "$whl" -d /tmp/wheel-check
          echo "Wheel contents:"
          find /tmp/wheel-check -type f | head -20
          rm -rf /tmp/wheel-check
        done

        # Check source distribution
        for tarball in dist/*.tar.gz; do
          echo ""
          echo "🔍 Checking source distribution: $(basename $tarball)"
          tar -tzf "$tarball" | head -20
        done

    - name: Check package metadata
      run: |
        python -m twine check dist/*

    - name: Test package installation
      run: |
        # Create fresh virtual environment
        python -m venv /tmp/test-env
        source /tmp/test-env/bin/activate

        # Install from wheel
        pip install dist/*.whl

        # Verify imports
        python -c "import preprimer; print(f'✅ PrePrimer version: {preprimer.__version__ if hasattr(preprimer, \"__version__\") else \"unknown\"}')"
        python -c "from preprimer.parsers import VarVAMPParser, ARTICParser, OlivarParser, STSParser; print('✅ All parsers imported successfully')"
        python -c "from preprimer.writers import ARTICWriter, VarVAMPWriter, OlivarWriter, FASTAWriter, STSWriter; print('✅ All writers imported successfully')"

        # Test CLI
        python -c "from preprimer import cli; print('✅ CLI module imported successfully')"

        # Verify package data included
        python -c "import importlib.resources; print('✅ Package resources accessible')"

        deactivate

    - name: Calculate checksums
      run: |
        cd dist/
        sha256sum * > SHA256SUMS
        cat SHA256SUMS

    - name: Upload build artifacts
      uses: actions/upload-artifact@v4
      with:
        name: distribution-packages
        path: |
          dist/*
        retention-days: 7

  # Publish to Test PyPI (optional safety check)
  publish-testpypi:
    name: Publish to Test PyPI
    runs-on: ubuntu-latest
    needs: build-package
    if: github.event_name == 'push' && startsWith(github.ref, 'refs/tags/v')
    environment:
      name: testpypi
      url: https://test.pypi.org/project/preprimer/
    permissions:
      id-token: write  # OIDC for trusted publishing

    steps:
    - name: Download build artifacts
      uses: actions/download-artifact@v4
      with:
        name: distribution-packages
        path: dist/

    - name: Publish to Test PyPI
      uses: pypa/gh-action-pypi-publish@release/v1
      with:
        repository-url: https://test.pypi.org/legacy/
        skip-existing: true
        verbose: true

    - name: Test installation from Test PyPI
      run: |
        sleep 30  # Wait for package to be available

        python -m venv /tmp/testpypi-env
        source /tmp/testpypi-env/bin/activate

        # Install from Test PyPI with production dependencies
        pip install --index-url https://test.pypi.org/simple/ \
                    --extra-index-url https://pypi.org/simple/ \
                    preprimer || echo "⚠️  Test PyPI installation check (may fail if version exists)"

        deactivate

  # Publish to production PyPI
  publish-pypi:
    name: Publish to PyPI
    runs-on: ubuntu-latest
    needs: [build-package, validate-release]
    if: github.event_name == 'release' || (github.event_name == 'push' && startsWith(github.ref, 'refs/tags/v'))
    environment:
      name: pypi
      url: https://pypi.org/project/preprimer/
    permissions:
      id-token: write  # OIDC for trusted publishing
      contents: write  # To upload release assets

    steps:
    - name: Download build artifacts
      uses: actions/download-artifact@v4
      with:
        name: distribution-packages
        path: dist/

    - name: Publish to PyPI
      uses: pypa/gh-action-pypi-publish@release/v1
      with:
        verbose: true

    - name: Create release summary
      run: |
        echo "## 🚀 PyPI Publication Successful" >> $GITHUB_STEP_SUMMARY
        echo "" >> $GITHUB_STEP_SUMMARY
        echo "**Package:** preprimer" >> $GITHUB_STEP_SUMMARY
        echo "**Version:** ${GITHUB_REF#refs/tags/v}" >> $GITHUB_STEP_SUMMARY
        echo "**PyPI URL:** https://pypi.org/project/preprimer/" >> $GITHUB_STEP_SUMMARY
        echo "" >> $GITHUB_STEP_SUMMARY
        echo "### 📦 Distribution Files" >> $GITHUB_STEP_SUMMARY
        ls -1 dist/ | sed 's/^/- /' >> $GITHUB_STEP_SUMMARY
        echo "" >> $GITHUB_STEP_SUMMARY
        echo "### 📝 Installation" >> $GITHUB_STEP_SUMMARY
        echo '```bash' >> $GITHUB_STEP_SUMMARY
        echo 'pip install preprimer' >> $GITHUB_STEP_SUMMARY
        echo '```' >> $GITHUB_STEP_SUMMARY

    - name: Upload release assets (if GitHub release)
      if: github.event_name == 'release'
      uses: softprops/action-gh-release@v1
      with:
        files: |
          dist/*
          dist/SHA256SUMS
      env:
        GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}

  # Post-publication verification
  verify-publication:
    name: Verify PyPI Publication
    runs-on: ${{ matrix.os }}
    needs: publish-pypi
    strategy:
      matrix:
        os: [ubuntu-latest, macos-latest]
        python-version: ["3.11", "3.12", "3.13"]

    steps:
    - name: Set up Python ${{ matrix.python-version }}
      uses: actions/setup-python@v5
      with:
        python-version: ${{ matrix.python-version }}

    - name: Wait for PyPI propagation
      run: |
        sleep 120  # Wait 2 minutes for PyPI CDN to propagate

    - name: Install from PyPI
      run: |
        pip install preprimer

    - name: Verify installation
      run: |
        python -c "import preprimer; print(f'✅ PrePrimer version: {preprimer.__version__ if hasattr(preprimer, \"__version__\") else \"unknown\"}')"
        python -c "from preprimer.parsers import VarVAMPParser, ARTICParser, OlivarParser, STSParser; print('✅ All parsers available')"
        python -c "from preprimer.writers import ARTICWriter, VarVAMPWriter, OlivarWriter, FASTAWriter, STSWriter; print('✅ All writers available')"

    - name: Smoke test
      run: |
        python -c "
        from preprimer.core.interfaces import PrimerData, AmpliconData
        from preprimer.parsers import VarVAMPParser
        print('✅ Core interfaces accessible')
        print('✅ Package fully functional')
        "

  # Publication summary
  publication-summary:
    name: Publication Summary
    runs-on: ubuntu-latest
    needs: [publish-pypi, verify-publication]
    if: always()

    steps:
    - name: Generate summary
      run: |
        echo "## 📊 Publication Summary" >> $GITHUB_STEP_SUMMARY
        echo "" >> $GITHUB_STEP_SUMMARY
        echo "**Release Tag:** ${GITHUB_REF#refs/tags/}" >> $GITHUB_STEP_SUMMARY
        echo "**Validation:** ${{ needs.validate-release.result }}" >> $GITHUB_STEP_SUMMARY
        echo "**Build:** ${{ needs.build-package.result }}" >> $GITHUB_STEP_SUMMARY
        echo "**PyPI Publication:** ${{ needs.publish-pypi.result }}" >> $GITHUB_STEP_SUMMARY
        echo "**Installation Verification:** ${{ needs.verify-publication.result }}" >> $GITHUB_STEP_SUMMARY
        echo "" >> $GITHUB_STEP_SUMMARY

        if [[ "${{ needs.publish-pypi.result }}" == "success" && "${{ needs.verify-publication.result }}" == "success" ]]; then
          echo "### ✅ Publication Successful" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "The package is now available on PyPI:" >> $GITHUB_STEP_SUMMARY
          echo "https://pypi.org/project/preprimer/" >> $GITHUB_STEP_SUMMARY
        else
          echo "### ❌ Publication Issues Detected" >> $GITHUB_STEP_SUMMARY
          echo "" >> $GITHUB_STEP_SUMMARY
          echo "Please review the workflow logs for details." >> $GITHUB_STEP_SUMMARY
        fi
